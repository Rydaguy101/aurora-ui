{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Aurora UI Registry",
  "type": "object",
  "required": ["name", "version", "components", "categoryOrder"],
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "repository": { "type": "string", "format": "uri" },
    "registryUrl": { "type": "string", "format": "uri" },
    "aiDocsUrl": { "type": "string", "format": "uri" },
    "categoryOrder": { "type": "array", "items": { "type": "string" } },
    "componentCount": { "type": "number" },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "title", "category", "description", "sourcePath", "sourceUrl"],
        "properties": {
          "slug": { "type": "string" },
          "title": { "type": "string" },
          "category": { "type": "string" },
          "description": { "type": "string" },
          "sourcePath": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "peerDependencies": { "type": "array", "items": { "type": "string" } },
          "importExample": { "type": "string" },
          "sourceUrl": { "type": "string", "format": "uri" }
        }
      }
    }
  }
}
