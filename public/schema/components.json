{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Aurora UI components.json",
  "description": "Project configuration for Aurora UI and shadcn-compatible CLI workflows.",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "style": { "type": "string", "default": "aurora" },
    "rsc": { "type": "boolean", "default": true },
    "tsx": { "type": "boolean", "default": true },
    "tailwind": {
      "type": "object",
      "properties": {
        "config": { "type": "string" },
        "css": { "type": "string" },
        "cssVariables": { "type": "boolean" }
      }
    },
    "aliases": {
      "type": "object",
      "properties": {
        "components": { "type": "string" },
        "utils": { "type": "string" },
        "ui": { "type": "string" },
        "lib": { "type": "string" }
      }
    },
    "iconLibrary": { "type": "string", "default": "lucide" },
    "registries": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "required": ["aliases", "registries"]
}
